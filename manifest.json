{
  "manifest_version": 3,
  "name": "ReplyAI — Smart Reply Suggestions",
  "version": "1.0.0",
  "description": "Context-aware AI reply suggestions that live inside your conversations. Works on WhatsApp Web, Instagram, Hinge, and more.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://www.instagram.com/*",
    "https://hinge.co/*",
    "https://www.hinge.co/*",
    "https://api.groq.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/service_worker.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*",
        "https://www.instagram.com/*",
        "https://hinge.co/*",
        "https://www.hinge.co/*"
      ],
      "js": ["content/reader.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
